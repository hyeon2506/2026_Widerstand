
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CASTING SCHEDULE</title>
<style>
body{
    margin:0;
    background:#f4efe7;
    font-family:'Noto Sans KR', sans-serif;
    color:#4a4037;
}
.container{
    max-width:1200px;
    margin:40px auto;
    padding:20px;
    position:relative;
}
.title{
    text-align:center;
    font-family:"Times New Roman", serif;
    font-size:54px;
    color:#7a6046;
    letter-spacing:2px;
    margin-bottom:30px;
}
.schedule-wrap{
    display:flex;
    align-items:stretch;
}
table{
    width:100%;
    border-collapse:collapse;
    background:#f8f4ee;
}
thead th{
    padding:12px 8px;
    border-top:2px solid #bcae9c;
    border-bottom:2px solid #bcae9c;
    color:#5f4935;
    font-size:15px;
}
tbody td{
    padding:10px 8px;
    border-bottom:1px solid #d8cdbf;
    text-align:center;
    font-size:14px;
}
tbody tr:hover{
    background:#f1ebe2;
}
.date{font-weight:700;}
.sat{color:#3f6fb4;font-weight:700;}
.sun{color:#c45151;font-weight:700;}
.time{font-weight:700;color:#6f6358;}
.xmark{color:#b15a5a;}
.preview{
    writing-mode:vertical-rl;
    text-orientation:mixed;
    padding-left:20px;
    font-family:"Times New Roman", serif;
    color:#8b6f54;
    font-size:34px;
    letter-spacing:2px;
}
/* 캐릭터 필터 */
.character-filter{
    display:flex;
    justify-content:center;
    gap:8px;
    flex-wrap:wrap;
    margin-bottom:20px;
}

.filter-btn{
    padding:8px 16px;
    border:1px solid #d8cdbf;
    background:#fff;
    color:#5f4935;
    cursor:pointer;
    border-radius:20px;
    font-size:13px;
    transition:all .2s;
}

.filter-btn:hover,
.filter-btn.active{
    background:#7a6046;
    color:#fff;
}

/* 월 구분선 */
.month-divider td{
    background:#7a6046;
    color:#fff;
    text-align:center;
    font-weight:700;
    letter-spacing:2px;
    padding:12px;
}

/* 오늘 공연 강조 */
.today-row{
    background:#fff6dd;
    border-left:5px solid #c59b4d;
}

.today-row td{
    font-weight:600;
}

/* 배우 색상 */
.actor{
    display:inline-block;
    padding:4px 10px;
    border-radius:20px;
    font-size:13px;
    font-weight:600;
}

.actor-blue{
    background:#e7f0ff;
    color:#2d5ca8;
}

.actor-pink{
    background:#ffe8ef;
    color:#b04c72;
}

.actor-green{
    background:#e8f8ec;
    color:#2f7c4a;
}

.actor-orange{
    background:#fff1e6;
    color:#b7662a;
}

.actor-purple{
    background:#f1e8ff;
    color:#6d46b3;
}

.actor-yellow{
    background:#fff7d9;
    color:#8c7000;
}

/* 모바일 */
@media (max-width:768px){

    .schedule-wrap{
        display:block;
    }

    .preview{
        display:none;
    }

    table,
    thead,
    tbody,
    tr,
    td{
        display:block;
        width:100%;
    }

    thead{
        display:none;
    }

    tr{
        background:#fff;
        margin-bottom:12px;
        border:1px solid #d8cdbf;
        border-radius:10px;
        padding:10px;
    }

    td{
        text-align:left;
        border:none;
        padding:4px 0;
    }

    .month-divider td{
        text-align:center;
    }
}
</style>
</head>
<body>
<div class="container">
    <div class="title">CASTING SCHEDULE</div>
<div class="character-filter">
    <button class="filter-btn active">전체</button>
    <button class="filter-btn">매그너스</button>
    <button class="filter-btn">아벨</button>
    <button class="filter-btn">프레드릭</button>
    <button class="filter-btn">하켄</button>
    <button class="filter-btn">재스퍼</button>
    <button class="filter-btn">클레어</button>
</div>
    <div class="schedule-wrap">
        <table>
            <thead>
                <tr>
                    <th>날짜</th>
                    <th>요일</th>
                    <th>시간</th>
                    <th>매그너스</th>
                    <th>아벨</th>
                    <th>프레드릭</th>
                    <th>하켄</th>
                    <th>재스퍼</th>
                    <th>클레어</th>
                </tr>
            </thead>
            <tbody>
                 <!-- 월 변경 -->
                     <tr class="month-divider">
                         <td colspan="9">AUGUST 2026</td>
                     </tr>

                     <tr>
                         <td class="date">8월 2일</td>
                         <td class="sun">일</td>
                         <td class="time">14:00</td>

                         <td><span class="actor actor-blue">황순종</span></td>
                         <td><span class="actor actor-pink">강병훈</span></td>
                         <td><span class="actor actor-green">김준식</span></td>
                         <td><span class="actor actor-orange">황건우</span></td>
                         <td><span class="actor actor-purple">김도민</span></td>
                         <td><span class="actor actor-yellow">고철순</span></td>
                     </tr>
                <tr>
                    <td class="date">7월 23일</td>
                    <td>목</td>
                    <td class="time">19:30</td>
                    <td class="xmark">✕ 최석진</td>
                    <td class="xmark">✕ 박정원</td>
                    <td class="xmark">✕ 김도현</td>
                    <td class="xmark">✕ 조모세</td>
                    <td class="xmark">✕ 김태환</td>
                    <td class="xmark">✕ 김보현</td>
                </tr>
                <tr>
                    <td class="date">7월 25일</td>
                    <td class="sat">토</td>
                    <td class="time">14:00</td>
                    <td>황순종</td>
                    <td>강병훈</td>
                    <td>김준식</td>
                    <td>황건우</td>
                    <td>김도민</td>
                    <td>고철순</td>
                </tr>
                <tr>
                    <td class="date">7월 25일</td>
                    <td class="sat">토</td>
                    <td class="time">18:30</td>
                    <td>최석진</td>
                    <td>박정원</td>
                    <td>김범연</td>
                    <td>김지웅</td>
                    <td>김태환</td>
                    <td>김보현</td>
                </tr>
                <tr>
                    <td class="date">8월 2일</td>
                    <td class="sun">일</td>
                    <td class="time">14:00</td>
                    <td>황순종</td>
                    <td>강병훈</td>
                    <td>김준식</td>
                    <td>황건우</td>
                    <td>김도민</td>
                    <td>고철순</td>
                </tr>
            </tbody>
        </table>

        <div class="preview">PREVIEW</div>
    </div>
</div>
</body>
</html>
