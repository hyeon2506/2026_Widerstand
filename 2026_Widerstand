 });
}
document.querySelectorAll('.actor-filter').forEach(b=>{
 b.onclick=()=>filterActor(b.dataset.actor);
});
document.getElementById('showAll').onclick=()=>{
 document.querySelectorAll('.schedule-row').forEach(r=>r.style.display='');
};
document.querySelectorAll('.actor').forEach(a=>{
 a.onclick=()=>filterActor(a.dataset.actor);
});
